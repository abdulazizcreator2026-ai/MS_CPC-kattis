n=int(input())
lst=list(map(int,input().split()))
Sereja=0
Dima=0
while len(lst)!=0:
    if lst[0]>=lst[-1]:
        Sereja+=lst[0]
        lst.pop(0)
    else:
        Sereja+=lst[-1]  
        lst.pop(-1)  
    if len(lst)!=0:
        if lst[0]>=lst[-1]:
            Dima+=lst[0]
            lst.pop(0)
        else:
            Dima+=lst[-1]  
            lst.pop(-1)
print(Sereja,Dima)