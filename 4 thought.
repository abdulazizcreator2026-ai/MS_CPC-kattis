ops=['+','-','*','/']
answers={}
for op1 in ops:
    for op2 in ops:
        for op3 in ops:
            expr=f"4 {op1} 4 {op2} 4 {op3} 4"
            value=eval(expr.replace('/','//'))
            answers[value]=expr
m=int(input())
for i in range(m):
    n=int(input())
    if n in answers:
        print(f"{answers[n]} = {n}") 
    else:
        print("no solution")               