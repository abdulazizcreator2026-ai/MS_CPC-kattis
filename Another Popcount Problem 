import sys

def solve():
    data = sys.stdin.buffer.read().split()
    t = int(data[0])
    idx = 1
    out = []
    for _ in range(t):
        n = int(data[idx]); k = int(data[idx + 1])
        idx += 2
        total = 0
        i = 0
        cost = k
        while n >= cost:
            n -= cost
            total += k
            i += 1
            cost = k << i
        total += n >> i
        out.append(str(total))
    sys.stdout.write("\n".join(out) + "\n")

solve()