t=int(input()) 
for _ in range(t):
    n=int(input())
    a=list(map(int,input().split()))
    a.sort()
    if n>1:
        for i in range(1,n):
            if a[i]==a[i-1]:
                print("NO")
                break
            elif i==n-1:
                print("YES")    
    else:
        print("YES")