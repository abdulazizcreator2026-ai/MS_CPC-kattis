t=int(input())
for i in range(t):
    n=int(input())
    a=list(map(int,input().split()))
    if n%2==0:
        even=0
        odd=0
        for i in a:
            if i%2==0:
                even+=1
            else:
                odd+=1
        if even<odd:
            print((n//2)-even)
        else:
            print((n//2)-odd)              
    else:
        print(-1)

        